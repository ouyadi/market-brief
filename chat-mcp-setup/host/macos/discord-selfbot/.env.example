# Copy this file to ~/.discord-selfbot.env and chmod 600.
# Self-bot violates Discord ToS. Use a burner account, not your main.

DISCORD_USER_TOKEN=

# Optional. Where the MCP HTTP server listens. Defaults shown.
MCP_HOST=127.0.0.1
MCP_PORT=6280

# Optional. discord.py-self log verbosity (DEBUG/INFO/WARNING).
LOG_LEVEL=INFO

# Optional. Set to "invisible" to keep the burner showing offline.
# One of: online, idle, dnd, invisible
DISCORD_STATUS=invisible
